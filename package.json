{
  "name": "mytunes",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.mytunes.app",
    "productName": "MyTunes",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*"
    ]
  },
  "keywords": [],
  "author": "Frohrer",
  "license": "MIT",
  "description": "Transfer .m4r ringtones to iPhone over USB — no iTunes needed",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "bplist-parser": "^0.3.2",
    "music-metadata": "^11.12.3",
    "plist": "^3.1.0",
    "usbmux-client": "^0.2.1"
  }
}
